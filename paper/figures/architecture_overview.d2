direction: down

# ── Global styling ──
*.style.font-size: 14

# ── Input ──
input: Input Tokens {
  shape: rectangle
  style.fill: "#f2f3f5"
  style.stroke: "#9e9e9e"
  style.border-radius: 8
  style.font-size: 13
}

# ── Token Embeddings ──
embed: Token Embeddings {
  shape: rectangle
  style.fill: "#e3ecf7"
  style.stroke: "#5c7cba"
  style.border-radius: 6
  style.font-size: 14
}

# ── B1 SurpriseGate ──
b1: B1  SurpriseGate {
  shape: rectangle
  style.fill: "#dcedc8"
  style.stroke: "#558b2f"
  style.border-radius: 6
  style.font-size: 14
  style.bold: true
}

# ── Middle row: B2-write | Stack | B3/B6 ──
mid: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  b2_write: "B2  EpisodicMemory\n(write)" {
    shape: rectangle
    style.fill: "#dcedc8"
    style.stroke: "#558b2f"
    style.border-radius: 6
    style.font-size: 13
    style.bold: true
  }

  stack: Transformer Stack (32 layers) {
    style.fill: "#f0f4fa"
    style.stroke: "#8da4c7"
    style.border-radius: 8
    style.font-size: 12
    style.font-color: "#6a7fa3"

    layer_n: Layer N {
      shape: rectangle
      style.fill: "#ffffff"
      style.stroke: "#b0bec5"
      style.border-radius: 4
      style.font-size: 12
    }

    dots: "⋮" {
      shape: text
      style.font-size: 18
      style.font-color: "#9e9e9e"
    }

    layer_1: Layer 1 {
      shape: rectangle
      style.fill: "#ffffff"
      style.stroke: "#b0bec5"
      style.border-radius: 4
      style.font-size: 12
    }

    layer_n -> dots
    dots -> layer_1
  }

  right_blocks: "" {
    direction: down
    style.fill: transparent
    style.stroke: transparent

    b3: "B3  PerLayerCritic\nevery 4th layer" {
      shape: rectangle
      style.fill: "#dcedc8"
      style.stroke: "#558b2f"
      style.border-radius: 6
      style.font-size: 13
      style.bold: true
    }

    b4: "B4  PredictiveCoding\n(Phase 2)" {
      shape: rectangle
      style.fill: "#ffe0cc"
      style.stroke: "#d84315"
      style.stroke-dash: 5
      style.border-radius: 6
      style.font-size: 13
      style.bold: true
    }

    b6: "B6  HomeostaticNorm\nwraps all norms" {
      shape: rectangle
      style.fill: "#dcedc8"
      style.stroke: "#558b2f"
      style.border-radius: 6
      style.font-size: 13
      style.bold: true
    }

    b3 -> b4: {style.opacity: 0}
    b4 -> b6: {style.opacity: 0}
  }

  b2_write -> stack: {style.opacity: 0}
  stack -> right_blocks: {style.opacity: 0}
}

# ── B2 read ──
b2_read: B2  EpisodicMemory (read) {
  shape: rectangle
  style.fill: "#dcedc8"
  style.stroke: "#558b2f"
  style.border-radius: 6
  style.font-size: 14
  style.bold: true
}

# ── Bottom row: B5 deferred + LM Head ──
bottom: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  lm_head: LM Head {
    shape: rectangle
    style.fill: "#e3ecf7"
    style.stroke: "#5c7cba"
    style.border-radius: 8
    style.font-size: 14
  }

  b5: "B5  RLGatingPolicy\n(Phase 2)" {
    shape: rectangle
    style.fill: "#ffe0cc"
    style.stroke: "#d84315"
    style.stroke-dash: 5
    style.border-radius: 6
    style.font-size: 13
    style.bold: true
  }

  lm_head -> b5: {style.opacity: 0}
}

# ═══════════════════════════════════════
#  Main vertical flow
# ═══════════════════════════════════════
input -> embed
embed -> b1
b1 -> mid.stack: ""
b1 -> mid.b2_write: {
  style.stroke: "#558b2f"
}
mid.stack.layer_n -> mid.right_blocks.b3: {
  style.stroke: "#558b2f"
}
mid.stack -> mid.right_blocks.b4: {
  style.stroke: "#d84315"
  style.stroke-dash: 4
}
mid.stack.layer_1 -> mid.right_blocks.b6: {
  style.stroke: "#558b2f"
}
mid.stack -> b2_read
b2_read -> bottom.lm_head

# ═══════════════════════════════════════
#  Legend (top-right)
# ═══════════════════════════════════════
legend: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  near: top-right

  l1: "Phase 1" {
    shape: rectangle
    style.fill: "#dcedc8"
    style.stroke: "#558b2f"
    style.border-radius: 4
    style.font-size: 11
  }
  l2: "Phase 2" {
    shape: rectangle
    style.fill: "#ffe0cc"
    style.stroke: "#d84315"
    style.stroke-dash: 5
    style.border-radius: 4
    style.font-size: 11
  }
  l3: "Base" {
    shape: rectangle
    style.fill: "#e3ecf7"
    style.stroke: "#5c7cba"
    style.border-radius: 4
    style.font-size: 11
  }
}
